{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Definition Schema",
  "type": "object",
  "required": ["version", "metadata", "nodes", "edges", "executionConfig"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Workflow version in semantic format (e.g., 1.0)"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "description", "author", "tags"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Workflow name"
        },
        "description": {
          "type": "string",
          "maxLength": 500,
          "description": "Workflow description"
        },
        "author": {
          "type": "string",
          "minLength": 1,
          "description": "Workflow author"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "description": "Workflow tags for categorization"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      }
    },
    "globals": {
      "type": "object",
      "description": "Global variables accessible in node configurations",
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["id", "type", "position", "data"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique node identifier"
          },
          "type": {
            "type": "string",
            "enum": ["data_loader", "model_inference", "resource_alloc", "evaluator", "reporter"],
            "description": "Node type"
          },
          "position": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0,
                "description": "X coordinate"
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "description": "Y coordinate"
              }
            }
          },
          "data": {
            "type": "object",
            "required": ["label", "config"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1,
                "description": "Node display label"
              },
              "icon": {
                "type": "string",
                "description": "Node icon identifier"
              },
              "config": {
                "type": "object",
                "description": "Node-specific configuration parameters",
                "additionalProperties": true
              },
              "status": {
                "type": "string",
                "enum": ["pending", "running", "success", "failed", "warning"],
                "description": "Node execution status"
              },
              "errorMessage": {
                "type": "string",
                "description": "Error message if node failed"
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "target"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Unique edge identifier"
          },
          "source": {
            "type": "string",
            "minLength": 1,
            "description": "Source node ID"
          },
          "target": {
            "type": "string",
            "minLength": 1,
            "description": "Target node ID"
          },
          "label": {
            "type": "string",
            "description": "Edge label (optional)"
          }
        }
      }
    },
    "executionConfig": {
      "type": "object",
      "required": ["timeoutSeconds", "retryCount", "parallelism"],
      "properties": {
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400,
          "description": "Maximum execution time in seconds"
        },
        "retryCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Number of retry attempts on failure"
        },
        "parallelism": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum parallel executions"
        }
      }
    }
  }
}